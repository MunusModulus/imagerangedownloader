{
  "manifest_version": 3,
  "name": "Image Range Downloader",
  "version": "3.5",
  "description": "__MSG_extDescription__",

  "permissions": [
    "downloads",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "js/background.js"
  },

  "options_page": "options.html",

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "default_locale": "en",

  "icons": {
    "16": "ird_icon-16.png",
    "32": "ird_icon-32.png",
    "48": "ird_icon-48.png",
    "128": "ird_icon-128.png"
  }

}